{
  "name": "emp-rewards",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source employee recognition & rewards platform — part of the EmpCloud HRMS ecosystem",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/EmpCloud/emp-rewards.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "pnpm --filter @emp-rewards/server dev",
    "dev:client": "pnpm --filter @emp-rewards/client dev",
    "build": "pnpm -r run build",
    "build:server": "pnpm --filter @emp-rewards/server build",
    "build:client": "pnpm --filter @emp-rewards/client build",
    "test": "pnpm -r run test",
    "test:server": "pnpm --filter @emp-rewards/server test",
    "lint": "pnpm -r run lint",
    "db:migrate": "pnpm --filter @emp-rewards/server db:migrate",
    "db:seed": "pnpm --filter @emp-rewards/server db:seed",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
